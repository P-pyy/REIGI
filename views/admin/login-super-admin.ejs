<link rel="stylesheet" href="/css/login.css" />
  <main class="login-container" role="main" aria-label="Reset Password Form">
    <div class="login-div">
      <div class="logo-container">
            <img src="/img/URS LOGO.png" alt="URS logo" onerror="this.style.display='none'" />
            <div class="logo-text">
              <span>University of</span>
              <span>Rizal System</span>
            </div>
      </div>
    </div>
    

    <form id="super-admin-loginForm" autocomplete="off">
      <h2 class="form-title">Welcome, Super Admin</h2>

      <div class="input-div">
        <div class="cb-wrap" id="cb1">
          <div class="cb-input-row">
            <input id="cb1-input" class="cb-input" type="text" placeholder="Select Campus" role="combobox" aria-expanded="false" aria-haspopup="listbox" required/>
            <button type="button" class="cb-arrow" aria-label="Toggle dropdown">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
          </div>
          <div id="cb1-list" class="cb-dropdown" role="listbox"></div>
        </div>

        <input id="email" type="email" placeholder="Email" required minlength="8" />
        <div class="error-message" id="new-password-error" hidden>Min 8 characters required.</div>

        <input id="password" type="password" placeholder="Password" required minlength="8" />
        <div class="error-message" id="reenter-password-error" hidden>Passwords do not match.</div>

        <!-- ✅ Extras div same as login.html -->
        <div class="extras">
          <label class="show-pass">
            <input type="checkbox" id="showPassword"> Show Password
          </label>
          <a href="/admin/login_enter_email" class="create-account" role="link">Create Account here</a>
        </div>
      </div>

      <button type="submit">Sign In</button>
    </form>

    <!-- ✅ Status message -->
    <p id="resetStatus" class="status-message"></p>
  </main>
  
  <script type="module" src="/js/login.js"></script>

